# --- required ---
OPENAI_API_KEY=sk-...your-realtime-capable-key...

# --- Claude (for the claude_chat tool: send requests to Claude, hear the reply) ---
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# --- Claude Code bridge (delegate_to_claude / check_claude) ---
# Needs the `claude` CLI on PATH (claude --version). Windows install (no Node):
#   irm https://claude.ai/install.ps1 | iex   (then open a new terminal)
# VOICEOS_CLAUDE_CWD=C:\path\to\a\project\you\trust
# Default bypassPermissions so the delegated agent runs unattended (no one to
# click "approve" hands-free); use acceptEdits to pause outside the workspace.
# VOICEOS_CLAUDE_PERMISSION_MODE=bypassPermissions
# VOICEOS_CLAUDE_EXTRA_ARGS=--model sonnet

# --- GitHub (github_status + review_with_claude: recent work & cloud jobs) ---
# Checks recent work / cloud Claude Code jobs by voice. With a TOKEN the repo is
# AUTO-DISCOVERED (no hardcoding) — "what have I been working on" finds your most
# recently active repos. Token: Settings -> Developer settings -> Tokens (repo scope).
# GITHUB_TOKEN=ghp_...
# VOICEOS_GITHUB_REPO=owner/name   # optional default for "how's it going" with no repo named

# --- Cider music player (for cider_control) ---
# Enable the API + copy the token at: Cider -> Settings -> Connectivity ->
# Manage External Application Access. Leave token blank if you disabled auth.
# CIDER_API_TOKEN=
# CIDER_API_BASE=http://localhost:10767
# CIDER_STOREFRONT=us

# --- optional: pick a mic by name substring (else system default) ---
# VOICEOS_MIC=Scarlett

# --- optional: hold-to-talk key (default f13; bind it to a mouse button). A key
#     name or a raw scan code — find yours with: python voice_agent.py --detect-key
# VOICEOS_HOTKEY=f13

# --- optional: force a browser for web_search ("chrome" or "msedge") ---
# VOICEOS_BROWSER=msedge

# --- optional: OBS WebSocket password (else read from OBS config file) ---
# OBS_WS_PASSWORD=

# --- optional: Spotify Web API for EXACT-track play (needs Premium) ---
# SPOTIPY_CLIENT_ID=
# SPOTIPY_CLIENT_SECRET=
# SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- optional: tune the Premiere Program-Monitor focus click (fractions 0..1) ---
# PREMIERE_FOCUS_X=0.72
# PREMIERE_FOCUS_Y=0.30
